---
import Layout from '../layouts/Base.astro';
import Button from '../components/ui/button/Button.astro';
import { supabase } from '../lib/Supabase.js';

const pageTitle = "The Vault";
const pageDescription = "Access the sealed archives of the Order of the 19th";

// Get the current session
const { data: { session } } = await supabase.auth.getSession();

let familyName = null;

// If authenticated, sync user to members table
if (session) {
  const { id, email } = session.user;
  familyName = session.user.user_metadata?.family_name || null;
  
  console.log('User session found:', { id, email, familyName });
  
  // Upsert user into members table
  const { error: upsertError } = await supabase
    .from('members')
    .upsert({ 
      id: id, 
      email: email, 
      family_name: familyName 
    }, { 
      onConflict: 'id' 
    });
  
  if (upsertError) {
    console.error('Error syncing user to members table:', upsertError);
  } else {
    console.log('User synced to members table successfully');
  }
}

const isAuthenticated = !!session;
---

<Layout title={pageTitle} description={pageDescription}>
  <style>
    .vault-container {
      font-family: 'Atkinson', sans-serif;
      min-height: calc(100vh - 200px);
    }
    
    .gradient-text {
      background: linear-gradient(to right, #059669, #047857);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .dossier-card {
      transition: all 0.3s ease;
    }

    .dossier-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(5, 150, 105, 0.15);
    }

    .classified-stamp {
      position: relative;
      overflow: hidden;
    }

    .classified-stamp::before {
      content: "CLASSIFIED";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) rotate(-15deg);
      font-size: 4rem;
      font-weight: 900;
      color: rgba(4, 120, 87, 0.08);
      letter-spacing: 0.5rem;
      pointer-events: none;
      z-index: 0;
    }

    .data-table {
      border-collapse: collapse;
      width: 100%;
    }

    .data-table th {
      text-align: left;
      padding: 1rem;
      border-bottom: 2px solid rgba(5, 150, 105, 0.3);
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
    }

    .data-table td {
      padding: 1rem;
      border-bottom: 1px solid rgba(5, 150, 105, 0.1);
    }

    .data-table tr:hover {
      background: rgba(5, 150, 105, 0.05);
    }
  </style>

  {!isAuthenticated ? (
    <!-- UNAUTHENTICATED STATE: VAULT SEALED -->
    <div class="vault-container flex items-center justify-center px-4 py-24">
      <div class="max-w-2xl text-center">
        <!-- Lock Icon -->
        <div class="mb-8 flex justify-center">
          <svg class="w-24 h-24 text-[#047857] dark:text-[#34d399] opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>

        <!-- Heading -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-widest mb-6 !text-gray-900 dark:!text-[#34d399]">
          The Vault is Sealed
        </h1>

        <!-- Subtext -->
        <p class="text-xl md:text-2xl text-neutral-700 dark:text-neutral-400 mb-10 leading-relaxed">
          Only recognized Associates may view the Sealed Archives.
        </p>

        <!-- Divider -->
        <div class="mb-10 flex items-center justify-center gap-4">
          <div class="h-px w-16 bg-gradient-to-r from-transparent to-[#059669]"></div>
          <div class="w-2 h-2 rounded-full bg-[#047857] dark:bg-[#34d399]"></div>
          <div class="h-px w-16 bg-gradient-to-l from-transparent to-[#059669]"></div>
        </div>

        <!-- CTA Button -->
        <Button href="/contact" variant="primary" size="lg">
          Apply for Membership
        </Button>

        <!-- Additional Context -->
        <p class="mt-8 text-sm text-neutral-600 dark:text-neutral-500 italic">
          "The ledger remains closed to those who do not bear the seal."
        </p>
      </div>
    </div>
  ) : (
    <!-- AUTHENTICATED STATE: VAULT UNLOCKED -->
    <div class="vault-container px-4 py-16">
      <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="mb-12 text-center classified-stamp">
          <div class="inline-flex items-center gap-3 mb-4">
            <div class="w-3 h-3 rounded-full bg-[#059669] animate-pulse"></div>
            <span class="text-sm uppercase tracking-widest text-[#047857] dark:text-[#34d399] font-bold">
              Access Level: Associate
            </span>
          </div>
          
          <h1 class="text-4xl md:text-5xl font-bold uppercase tracking-widest mb-4 !text-gray-900 dark:!text-[#34d399]">
            Vault Access Granted
          </h1>
          
          <p class="text-lg text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
            {familyName ? `Welcome, Associate ${familyName}.` : 'Welcome to the Archives.'} Below are the unsealed records, submitted memories, and protected lore of the Order.
          </p>
        </div>

        <!-- Filter/Search Bar -->
        <div class="mb-8 flex flex-col md:flex-row gap-4 items-center justify-between">
          <div class="flex gap-3">
            <button class="px-4 py-2 rounded-lg bg-[#047857] dark:bg-[#059669] text-white text-sm font-semibold hover:opacity-90 transition">
              All Records
            </button>
            <button class="px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 text-sm font-semibold hover:bg-neutral-100 dark:hover:bg-neutral-800 transition">
              Submitted Stories
            </button>
            <button class="px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 text-sm font-semibold hover:bg-neutral-100 dark:hover:bg-neutral-800 transition">
              Historical Lore
            </button>
          </div>
          <div class="w-full md:w-auto">
            <input 
              type="search" 
              placeholder="Search the archives..." 
              class="w-full md:w-64 px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 text-neutral-800 dark:text-neutral-200 text-sm focus:ring-2 focus:ring-[#059669] focus:border-transparent"
            />
          </div>
        </div>

        <!-- Data Table View -->
        <div class="bg-white dark:bg-neutral-900 rounded-xl border border-neutral-200 dark:border-neutral-800 overflow-hidden mb-12">
          <table class="data-table">
            <thead class="bg-neutral-50 dark:bg-neutral-800/50">
              <tr>
                <th class="text-[#047857] dark:text-[#34d399]">Entry ID</th>
                <th class="text-[#047857] dark:text-[#34d399]">Title</th>
                <th class="text-[#047857] dark:text-[#34d399]">Date Archived</th>
                <th class="text-[#047857] dark:text-[#34d399]">Classification</th>
                <th class="text-[#047857] dark:text-[#34d399]">Status</th>
              </tr>
            </thead>
            <tbody class="text-neutral-700 dark:text-neutral-300">
              <!-- Placeholder Row 1 -->
              <tr>
                <td class="font-mono text-sm text-[#047857] dark:text-[#34d399]">XIX-1847-003</td>
                <td class="font-semibold">The Riverside Wager</td>
                <td>1847-08-12</td>
                <td><span class="px-2 py-1 rounded text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-400">Verified</span></td>
                <td><span class="text-xs uppercase tracking-wide text-[#059669] dark:text-[#34d399] font-bold">Unsealed</span></td>
              </tr>
              <!-- Placeholder Row 2 -->
              <tr>
                <td class="font-mono text-sm text-[#047857] dark:text-[#34d399]">XIX-1923-017</td>
                <td class="font-semibold">The Long Island Hustle</td>
                <td>1923-06-04</td>
                <td><span class="px-2 py-1 rounded text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-400">Verified</span></td>
                <td><span class="text-xs uppercase tracking-wide text-[#059669] dark:text-[#34d399] font-bold">Unsealed</span></td>
              </tr>
              <!-- Placeholder Row 3 -->
              <tr>
                <td class="font-mono text-sm text-[#047857] dark:text-[#34d399]">XIX-2024-142</td>
                <td class="font-semibold">The Night the Map Unraveled</td>
                <td>2024-11-19</td>
                <td><span class="px-2 py-1 rounded text-xs bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400">Submitted</span></td>
                <td><span class="text-xs uppercase tracking-wide text-neutral-500 dark:text-neutral-400 font-bold">Under Review</span></td>
              </tr>
              <!-- Placeholder Row 4 -->
              <tr>
                <td class="font-mono text-sm text-[#047857] dark:text-[#34d399]">XIX-1891-008</td>
                <td class="font-semibold">The Tiger on the Maidan</td>
                <td>1891-03-22</td>
                <td><span class="px-2 py-1 rounded text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-400">Verified</span></td>
                <td><span class="text-xs uppercase tracking-wide text-[#059669] dark:text-[#34d399] font-bold">Unsealed</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Dossier Card Grid (Alternative View) -->
        <div class="mb-8">
          <h2 class="text-2xl font-bold mb-6 !text-gray-900 dark:!text-[#34d399] uppercase tracking-wide">
            Featured Dossiers
          </h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Dossier Card 1 -->
            <div class="dossier-card bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-lg p-6 relative overflow-hidden">
              <div class="absolute top-4 right-4">
                <span class="px-2 py-1 rounded text-xs bg-[#059669]/10 text-[#047857] dark:text-[#34d399] font-bold uppercase tracking-wide">
                  Verified
                </span>
              </div>
              <div class="mb-4">
                <p class="text-xs font-mono text-[#047857] dark:text-[#34d399] mb-2">XIX-1847-003</p>
                <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-100 mb-2">
                  The Riverside Wager
                </h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  Edinburgh, Scotland • 1847
                </p>
              </div>
              <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed mb-4">
                A legendary match played for the keys to a distillery. The terms were simple: lose, and you forfeit your family's legacy...
              </p>
              <button class="text-sm font-semibold text-[#047857] dark:text-[#34d399] hover:underline">
                Read Full Account →
              </button>
            </div>

            <!-- Dossier Card 2 -->
            <div class="dossier-card bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-lg p-6 relative overflow-hidden">
              <div class="absolute top-4 right-4">
                <span class="px-2 py-1 rounded text-xs bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400 font-bold uppercase tracking-wide">
                  Submitted
                </span>
              </div>
              <div class="mb-4">
                <p class="text-xs font-mono text-[#047857] dark:text-[#34d399] mb-2">XIX-2024-142</p>
                <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-100 mb-2">
                  The Night the Map Unraveled
                </h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  San Francisco, USA • 2024
                </p>
              </div>
              <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed mb-4">
                A story submitted by a member about a mysterious course that appeared on a vintage map, leading to an unforgettable discovery...
              </p>
              <button class="text-sm font-semibold text-[#047857] dark:text-[#34d399] hover:underline">
                Read Full Account →
              </button>
            </div>

            <!-- Dossier Card 3 -->
            <div class="dossier-card bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-lg p-6 relative overflow-hidden">
              <div class="absolute top-4 right-4">
                <span class="px-2 py-1 rounded text-xs bg-[#059669]/10 text-[#047857] dark:text-[#34d399] font-bold uppercase tracking-wide">
                  Verified
                </span>
              </div>
              <div class="mb-4">
                <p class="text-xs font-mono text-[#047857] dark:text-[#34d399] mb-2">XIX-1891-008</p>
                <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-100 mb-2">
                  The Tiger on the Maidan
                </h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  Calcutta, India • 1891
                </p>
              </div>
              <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed mb-4">
                During colonial rule, a local champion faced a British officer in a match that would determine the fate of the course itself...
              </p>
              <button class="text-sm font-semibold text-[#047857] dark:text-[#34d399] hover:underline">
                Read Full Account →
              </button>
            </div>
          </div>
        </div>

        <!-- Bottom Notice -->
        <div class="mt-12 text-center">
          <p class="text-sm text-neutral-600 dark:text-neutral-500 italic">
            "These records are protected by the Order. Handle with discretion."
          </p>
        </div>
      </div>
    </div>
  )}
</Layout>

---
import { SITE_TITLE } from '../../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from '../ui/button/ThemeToggle.astro';
---

<header class="bg-background text-foreground border-b sw-header">
    <nav class="mx-auto max-w-6xl px-4 py-2 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="internal-links hidden md:flex items-center gap-2">
                <HeaderLink href="/" class="px-2 py-3 text-[color:var(--color-text-secondary)] no-underline">Home</HeaderLink>
                <HeaderLink href="/about" class="px-2 py-3 text-[color:var(--color-text-secondary)] no-underline">About the Order</HeaderLink>
                <HeaderLink href="/history" class="px-2 py-3 text-[color:var(--color-text-secondary)] no-underline">Our History</HeaderLink>
                <HeaderLink href="/the19" class="px-2 py-3 text-[color:var(--color-text-secondary)] no-underline">Inner Circle</HeaderLink>
                <HeaderLink href="/archive" class="px-2 py-3 text-[color:var(--color-text-secondary)] no-underline">The Archive</HeaderLink>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <div class="social-links hidden md:flex items-center gap-3">
                <!-- Reddit -->
                <a href="#" target="_blank" class="group text-[color:var(--color-text-secondary)]">
                    <span class="sr-only">Follow on Reddit</span>
                    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" class="transition-colors group-hover:text-[color:var(--accent)]"><path fill="currentColor" d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
                </a>
                <!-- Facebook -->
                <a href="#" target="_blank" class="group text-[color:var(--color-text-secondary)]">
                    <span class="sr-only">Follow on Facebook</span>
                    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" class="transition-colors group-hover:text-[color:var(--accent)]"><path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
            </div>
            <ThemeToggle />
            
            <!-- Mobile menu toggle button -->
            <button id="mobile-menu-toggle" class="md:hidden" aria-label="Toggle mobile menu">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
              </svg>
            </button>
        </div>
    </nav>
</header>

<style>
  /* Mobile: hide desktop-only nav items */
  .internal-links,
  .social-links {
    display: none;
  }

  /* Show nav items when mobile menu is toggled */
  nav.mobile-open {
    flex-direction: column;
  }

  nav.mobile-open .internal-links {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 1rem 0;
  }

  nav.mobile-open .social-links {
    display: flex;
    flex-wrap: wrap;
    padding: 1rem 0;
  }

  /* Desktop: show all navigation items, hide hamburger */
  @media screen and (min-width: 768px) {
    .internal-links,
    .social-links {
      display: flex !important;
    }
    
    nav.mobile-open .internal-links {
      flex-direction: row;
      width: auto;
      padding: 0;
    }

    nav.mobile-open .social-links {
      padding: 0;
    }
    
    #mobile-menu-toggle {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuButton = document.getElementById('mobile-menu-toggle');
    const nav = document.querySelector('nav');
    
    menuButton?.addEventListener('click', () => {
      nav?.classList.toggle('mobile-open');
    });
  });
</script>
